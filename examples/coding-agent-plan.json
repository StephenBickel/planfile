{
  "version": "0.1",
  "source": "coding-agent",
  "summary": "Add risk scoring notes and run typecheck",
  "operations": [
    {
      "id": "op_file_1",
      "type": "file",
      "action": "update",
      "path": "README.md",
      "after": "# planfile\n\nUpdated by coding agent plan example.\n"
    },
    {
      "id": "op_file_2",
      "type": "file",
      "action": "create",
      "path": "docs/notes.md",
      "after": "Risk rationale notes generated by agent.\n"
    },
    {
      "id": "op_cmd_1",
      "type": "command",
      "command": "npm run typecheck",
      "cwd": ".",
      "allowFailure": false
    }
  ],
  "preconditions": [
    {
      "kind": "git_clean",
      "description": "Avoid mixed apply with unrelated edits"
    },
    {
      "kind": "env_present",
      "value": "CI",
      "description": "Only run this plan in CI"
    }
  ]
}
